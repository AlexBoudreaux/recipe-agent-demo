# Copy to .env.local and fill in real values. .env* is gitignored.

# --- Vercel AI Gateway -------------------------------------------------------
# Single key for ALL model, embedding, and image calls. Bare string model ids
# (e.g. "openai/gpt-5.5") route through the gateway automatically. Centralized
# in src/lib/model.ts so swapping providers is a one-string change.
# Get it from the Vercel dashboard once the project exists (AI Gateway section).
AI_GATEWAY_API_KEY=

# --- Convex ------------------------------------------------------------------
# Generated by `npx convex dev` when it links the project. Do not hand-edit.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# --- Supadata ----------------------------------------------------------------
# Managed YouTube transcript API. Used for LIVE ingestion on Vercel (a later
# chunk). Local seeding uses a free direct-scrape path instead.
SUPADATA_API_KEY=
